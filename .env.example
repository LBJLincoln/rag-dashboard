# Nomos AI — Environment Variables Template
# Copy to .env.local and fill in values. NEVER commit .env.local to git!

# n8n Docker (VM)
N8N_HOST=http://localhost:5678
N8N_API_KEY=your-n8n-api-key
N8N_MCP_TOKEN=your-n8n-mcp-token

# LLM & Embeddings
OPENROUTER_API_KEY=sk-or-v1-xxx
COHERE_API_KEY=xxx
JINA_API_KEY=jina_xxx
HF_TOKEN=hf_xxx

# Databases
PINECONE_API_KEY=pcsk_xxx
PINECONE_HOST=https://your-index.svc.pinecone.io
NEO4J_URI=neo4j+s://xxx.databases.neo4j.io
NEO4J_PASSWORD=xxx
SUPABASE_API_KEY=sb_xxx
SUPABASE_PASSWORD=xxx
SUPABASE_URL=https://xxx.supabase.co

# Deployment (optional)
VERCEL_TOKEN=vck_xxx

# Docker n8n (for Codespace instances)
DB_POSTGRESDB_PASSWORD=n8npass
N8N_ENCRYPTION_KEY=change-me-encryption-key
