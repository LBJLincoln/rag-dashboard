# Environment Variables - SOTA 2026 Multi-RAG Orchestrator
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git!

# n8n Docker self-hosted (Google Cloud VM)
export N8N_HOST="http://34.136.180.66:5678"
export N8N_API_KEY="your-n8n-api-key"

# LLM & Embeddings
export OPENROUTER_API_KEY="your-openrouter-api-key"
export JINA_API_KEY="your-jina-api-key"
export COHERE_API_KEY="your-cohere-api-key"
export HF_TOKEN="your-huggingface-token"

# Databases
export PINECONE_API_KEY="your-pinecone-api-key"
export PINECONE_HOST="https://your-index.svc.your-region.pinecone.io"
export NEO4J_PASSWORD="your-neo4j-password"
export SUPABASE_PASSWORD="your-supabase-password"
export SUPABASE_API_KEY="your-supabase-api-key"
export SUPABASE_URL="https://your-project.supabase.co"
